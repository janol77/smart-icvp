       fhir:source ( [
         fhir:context [ fhir:v "sourceName" ] ;
         fhir:element [ fhir:v "suffix" ] ;
         fhir:variable [ fhir:v "suffix" ]
       ] ) ;
       fhir:target ( [
         fhir:context [ fhir:v "targetName" ] ;
         fhir:contextType [ fhir:v "variable" ] ;
         fhir:element [ fhir:v "suffix" ] ;
         fhir:transform [ fhir:v "copy" ] ;
